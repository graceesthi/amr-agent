# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The only value you MUST set is OPENAI_API_KEY. Everything else has a working
# default.
# ---------------------------------------------------------------------------

# --- OpenAI (required) -----------------------------------------------------
OPENAI_API_KEY=sk-...                       # get one at platform.openai.com
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=                          # only for Azure/proxy endpoints

# Self-Consistency: temperature MUST be > 0 or the k samples are identical.
SELF_CONSISTENCY_TEMPERATURE=0.7
SELF_CONSISTENCY_K=3

# --- RAGAS judge (eval only) ----------------------------------------------
# Blank = judge with the same model that answered (gpt-4o-mini). For an
# independent, stronger judge (recommended for the report) set gpt-4o.
RAGAS_JUDGE_MODEL=

# --- Reranker (the one local model) ---------------------------------------
# OpenAI has no reranking endpoint, so the cross-encoder is downloaded from
# HuggingFace on first run (~90 MB).
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Observability (Langfuse) ---------------------------------------------
# Free self-host or cloud.langfuse.com. Leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
AGENT_VERSION=1.0.0

# --- Budget ----------------------------------------------------------------
# Hard ceiling per run. When exceeded, the agent stops calling tools and
# synthesises from whatever evidence it has. See guardrails.TokenBudget.
TOKEN_BUDGET_PER_RUN=60000

# --- Retrieval tuning ------------------------------------------------------
RRF_K=60
CANDIDATES_PER_ARM=20
RERANK_TOP_N=5

# --- Data ------------------------------------------------------------------
CORPUS_DIR=data/seed
